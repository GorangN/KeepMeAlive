<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ DARK THEME — Status Updater ═══ -->
    <!-- Brand: neon green (#39FF14) = "alive / running" -->

    <Color x:Key="WindowColor">#050505</Color>
    <Color x:Key="SurfaceColor">#111111</Color>
    <Color x:Key="Surface2Color">#1C1C1C</Color>
    <Color x:Key="AccentColor">#39FF14</Color>
    <Color x:Key="AccentHoverColor">#52FF30</Color>
    <Color x:Key="ForegroundColor">#E8E8E8</Color>
    <Color x:Key="SubtleColor">#555555</Color>
    <Color x:Key="DangerColor">#FF4040</Color>
    <Color x:Key="BorderColor">#2A2A2A</Color>
    <Color x:Key="InputBgColor">#0A0A0A</Color>
    <Color x:Key="OverlayColor">#CC000000</Color>

    <SolidColorBrush x:Key="WindowBrush"      Color="{StaticResource WindowColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush"    Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush"  Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="SubtleBrush"      Color="{StaticResource SubtleColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"     Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="OverlayBrush"     Color="{StaticResource OverlayColor}"/>

    <!-- Running indicator: neon green glow -->
    <SolidColorBrush x:Key="RunningBrush"     Color="#39FF14"/>
    <SolidColorBrush x:Key="StoppedBrush"     Color="#333333"/>

</ResourceDictionary>
