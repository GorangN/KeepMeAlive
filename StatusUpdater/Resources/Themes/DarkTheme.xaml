<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ DARK THEME — Status Updater ═══ -->
    <!-- Apple dark palette: true black background, #1C1C1E cards, Apple Blue (#0A84FF) accent -->

    <Color x:Key="WindowColor">#000000</Color>
    <Color x:Key="SurfaceColor">#000000</Color>
    <Color x:Key="Surface2Color">#1C1C1E</Color>
    <Color x:Key="AccentColor">#0A84FF</Color>
    <Color x:Key="AccentHoverColor">#409CFF</Color>
    <Color x:Key="ForegroundColor">#FFFFFF</Color>
    <Color x:Key="SubtleColor">#8E8E93</Color>
    <Color x:Key="DangerColor">#FF453A</Color>
    <Color x:Key="BorderColor">#38383A</Color>
    <Color x:Key="InputBgColor">#2C2C2E</Color>
    <Color x:Key="ToggleOffColor">#39393D</Color>
    <Color x:Key="OverlayColor">#80000000</Color>

    <SolidColorBrush x:Key="WindowBrush"      Color="{StaticResource WindowColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush"    Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush"  Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="SubtleBrush"      Color="{StaticResource SubtleColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"     Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="ToggleOffBrush"   Color="{StaticResource ToggleOffColor}"/>
    <SolidColorBrush x:Key="OverlayBrush"     Color="{StaticResource OverlayColor}"/>

    <!-- Running indicator: iOS dark-mode green -->
    <SolidColorBrush x:Key="RunningBrush"     Color="#30D158"/>
    <SolidColorBrush x:Key="StoppedBrush"     Color="#48484A"/>

</ResourceDictionary>
