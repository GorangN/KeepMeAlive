<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ LIGHT THEME — Status Updater ═══ -->
    <!-- X.com light palette: white background, Twitter Blue (#1D9BF0) accent -->

    <Color x:Key="WindowColor">#FFFFFF</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="Surface2Color">#F7F9F9</Color>
    <Color x:Key="AccentColor">#1D9BF0</Color>
    <Color x:Key="AccentHoverColor">#1A8CD8</Color>
    <Color x:Key="ForegroundColor">#0F1419</Color>
    <Color x:Key="SubtleColor">#536471</Color>
    <Color x:Key="DangerColor">#F4212E</Color>
    <Color x:Key="BorderColor">#EFF3F4</Color>
    <Color x:Key="InputBgColor">#FFFFFF</Color>
    <Color x:Key="OverlayColor">#80000000</Color>

    <SolidColorBrush x:Key="WindowBrush"      Color="{StaticResource WindowColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush"    Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush"  Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="SubtleBrush"      Color="{StaticResource SubtleColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"     Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="OverlayBrush"     Color="{StaticResource OverlayColor}"/>

    <!-- Running indicator: Twitter green -->
    <SolidColorBrush x:Key="RunningBrush"     Color="#00BA7C"/>
    <SolidColorBrush x:Key="StoppedBrush"     Color="#CFD9DE"/>

</ResourceDictionary>
