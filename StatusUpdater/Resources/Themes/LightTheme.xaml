<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ LIGHT THEME — Digital Concierge palette ═══ -->

    <!-- Core surface scale -->
    <Color x:Key="BackgroundColor">#fbf8fe</Color>
    <Color x:Key="SurfaceColor">#fbf8fe</Color>
    <Color x:Key="SurfaceContainerLowColor">#f4f3fb</Color>
    <Color x:Key="SurfaceContainerLowestColor">#ffffff</Color>
    <Color x:Key="SurfaceContainerColor">#eeedf6</Color>
    <Color x:Key="SurfaceContainerHighColor">#e8e7f1</Color>
    <Color x:Key="SurfaceContainerHighestColor">#e2e1ed</Color>

    <!-- Primary / accent -->
    <Color x:Key="PrimaryColor">#505d8c</Color>
    <Color x:Key="PrimaryDimColor">#44517f</Color>
    <Color x:Key="PrimaryContainerColor">#bac7fd</Color>

    <!-- Text -->
    <Color x:Key="OnSurfaceColor">#30323b</Color>
    <Color x:Key="OnSurfaceVariantColor">#5d5e68</Color>
    <Color x:Key="OnPrimaryColor">#faf8ff</Color>

    <!-- Borders & outlines -->
    <Color x:Key="OutlineVariantColor">#b1b1bc</Color>
    <Color x:Key="OutlineColor">#797a84</Color>

    <!-- Semantic -->
    <Color x:Key="ErrorColor">#a8364b</Color>
    <Color x:Key="ErrorContainerColor">#f97386</Color>
    <Color x:Key="RunningColor">#34C759</Color>

    <!-- ═══ Brushes ═══ -->

    <SolidColorBrush x:Key="BackgroundBrush"               Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"                  Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerLowBrush"      Color="{StaticResource SurfaceContainerLowColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush"   Color="{StaticResource SurfaceContainerLowestColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush"         Color="{StaticResource SurfaceContainerColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerHighBrush"     Color="{StaticResource SurfaceContainerHighColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush"  Color="{StaticResource SurfaceContainerHighestColor}"/>

    <SolidColorBrush x:Key="PrimaryBrush"                  Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDimBrush"               Color="{StaticResource PrimaryDimColor}"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush"         Color="{StaticResource PrimaryContainerColor}"/>

    <SolidColorBrush x:Key="OnSurfaceBrush"                Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush"         Color="{StaticResource OnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="OnPrimaryBrush"                Color="{StaticResource OnPrimaryColor}"/>

    <SolidColorBrush x:Key="OutlineVariantBrush"           Color="{StaticResource OutlineVariantColor}"/>
    <SolidColorBrush x:Key="OutlineBrush"                  Color="{StaticResource OutlineColor}"/>

    <SolidColorBrush x:Key="ErrorBrush"                    Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorContainerBrush"           Color="{StaticResource ErrorContainerColor}"/>
    <SolidColorBrush x:Key="RunningBrush"                  Color="{StaticResource RunningColor}"/>

    <!-- 10 % primary tint — used for active sidebar nav item background -->
    <SolidColorBrush x:Key="NavItemActiveBgBrush"          Color="#1A505d8c"/>
    <SolidColorBrush x:Key="StoppedBrush"                  Color="{StaticResource SurfaceContainerHighestColor}"/>

    <!-- Legacy aliases — keep for any old references during transition -->
    <SolidColorBrush x:Key="WindowBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="Surface2Brush"    Color="{StaticResource SurfaceContainerLowColor}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource PrimaryDimColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush"  Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="SubtleBrush"      Color="{StaticResource OnSurfaceVariantColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource OutlineVariantColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"     Color="{StaticResource SurfaceContainerLowestColor}"/>
    <SolidColorBrush x:Key="ToggleOffBrush"   Color="{StaticResource SurfaceContainerHighestColor}"/>

</ResourceDictionary>
