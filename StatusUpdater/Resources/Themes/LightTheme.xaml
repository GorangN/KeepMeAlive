<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ LIGHT THEME — Status Updater ═══ -->

    <Color x:Key="WindowColor">#F0F0F0</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="Surface2Color">#EBEBEB</Color>
    <Color x:Key="AccentColor">#1A8C00</Color>
    <Color x:Key="AccentHoverColor">#22A800</Color>
    <Color x:Key="ForegroundColor">#1A1A1A</Color>
    <Color x:Key="SubtleColor">#999999</Color>
    <Color x:Key="DangerColor">#CC2200</Color>
    <Color x:Key="BorderColor">#D4D4D4</Color>
    <Color x:Key="InputBgColor">#F5F5F5</Color>
    <Color x:Key="OverlayColor">#99000000</Color>

    <SolidColorBrush x:Key="WindowBrush"      Color="{StaticResource WindowColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush"    Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="ForegroundBrush"  Color="{StaticResource ForegroundColor}"/>
    <SolidColorBrush x:Key="SubtleBrush"      Color="{StaticResource SubtleColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"     Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="OverlayBrush"     Color="{StaticResource OverlayColor}"/>

    <SolidColorBrush x:Key="RunningBrush"     Color="#1A8C00"/>
    <SolidColorBrush x:Key="StoppedBrush"     Color="#BBBBBB"/>

</ResourceDictionary>
