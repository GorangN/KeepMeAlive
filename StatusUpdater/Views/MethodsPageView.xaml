<UserControl x:Class="KeepMeAlive.Views.MethodsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KeepMeAlive.ViewModels">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40 36 40 36">

                <!-- Page header -->
                <TextBlock Text="Methods" Style="{StaticResource PageHeadlineStyle}"/>
                <TextBlock Text="Configure how KeepMeAlive simulates activity."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0 6 0 32"/>

                <!-- Method &amp; Interval card -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <StackPanel>

                        <!-- Card header -->
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 24">
                            <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBlock Text="Activity Method" Style="{StaticResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- Method row -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Simulation method"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="How KeepMeAlive signals activity to the system."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource ComboBoxStyle}"
                                          VerticalAlignment="Center"
                                          SelectedItem="{Binding SelectedMethod, Mode=TwoWay}"
                                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}">
                                    <ComboBox.Items>
                                        <vm:KeepAliveMethod>Keyboard</vm:KeepAliveMethod>
                                        <vm:KeepAliveMethod>Mouse</vm:KeepAliveMethod>
                                    </ComboBox.Items>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Interval row -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Interval"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Seconds between each pulse. Minimum 20 s."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource InputStyle}"
                                         Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="s"
                                           Style="{StaticResource FieldLabelStyle}"
                                           VerticalAlignment="Center"
                                           Margin="10 0 0 0"/>
                            </Grid>
                        </Border>

                        <!-- Keep awake row -->
                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Prevent sleep &amp; display off"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Uses Windows power management to keep the screen and system awake."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleCheckBoxStyle}"
                                          IsChecked="{Binding KeepAwakeEnabled}"
                                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
