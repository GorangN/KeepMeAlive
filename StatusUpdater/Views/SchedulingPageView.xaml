<UserControl x:Class="KeepMeAlive.Views.SchedulingPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:KeepMeAlive.Helpers">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40 36 40 36">

                <!-- Page header -->
                <TextBlock Text="Scheduling" Style="{StaticResource PageHeadlineStyle}"/>
                <TextBlock Text="Automatically trigger a system action at a specific date and time."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0 6 0 32"/>

                <!-- Scheduled action card -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <StackPanel>

                        <!-- Card header -->
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 24">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBlock Text="Scheduled Action" Style="{StaticResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- Enable toggle -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Enable scheduled action"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Run the selected action automatically at the specified time."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleCheckBoxStyle}"
                                          IsChecked="{Binding ScheduledActionEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Action type row -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Action"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="System action to execute at the scheduled time."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource ComboBoxStyle}"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding AvailableScheduledActions}"
                                          SelectedItem="{Binding SelectedScheduledAction, Mode=TwoWay}"
                                          IsEnabled="{Binding ScheduledActionEnabled}"/>
                            </Grid>
                        </Border>

                        <!-- Date / time row -->
                        <Border Style="{StaticResource SettingRowStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Date &amp; time"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBlock Text="When to run the action."
                                                   Style="{StaticResource SettingDescriptionStyle}"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource InputStyle}"
                                             VerticalAlignment="Center"
                                             IsEnabled="{Binding ScheduledActionEnabled}">
                                        <TextBox.Text>
                                            <Binding Path="ScheduledActionTime"
                                                     UpdateSourceTrigger="PropertyChanged"
                                                     Mode="TwoWay">
                                                <Binding.ValidationRules>
                                                    <helpers:DateTimeFormatValidationRule ValidatesOnTargetUpdated="False"/>
                                                </Binding.ValidationRules>
                                            </Binding>
                                        </TextBox.Text>
                                    </TextBox>
                                </Grid>
                                <TextBlock Text="Format: dd:MM:yyyy:HH:mm:ss  (e.g. 01:04:2026:22:30:00)"
                                           Style="{StaticResource FooterTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0 10 0 0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Save button row -->
                <Grid Margin="0 16 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Style="{StaticResource SaveButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Content="Save Changes"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
