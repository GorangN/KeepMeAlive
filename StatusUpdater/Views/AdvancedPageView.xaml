<UserControl x:Class="KeepMeAlive.Views.AdvancedPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KeepMeAlive.ViewModels">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40 36 40 36">

                <!-- Page header -->
                <TextBlock Text="Advanced" Style="{StaticResource PageHeadlineStyle}"/>
                <TextBlock Text="Configure simulation method and fine-tune low-level parameters."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0 6 0 32"/>

                <!-- Activity Method card -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 24">
                            <TextBlock Text="&#xE962;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBlock Text="Activity Method" Style="{StaticResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- Method row -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Simulation method"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="How KeepMeAlive signals activity to the system."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource ComboBoxStyle}"
                                          VerticalAlignment="Center"
                                          SelectedItem="{Binding SelectedMethod, Mode=TwoWay}"
                                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}">
                                    <ComboBox.Items>
                                        <vm:KeepAliveMethod>Keyboard</vm:KeepAliveMethod>
                                        <vm:KeepAliveMethod>Mouse</vm:KeepAliveMethod>
                                    </ComboBox.Items>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Interval row -->
                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Interval"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Seconds between each pulse. Minimum 20 s."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource InputStyle}"
                                         Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="s"
                                           Style="{StaticResource FieldLabelStyle}"
                                           VerticalAlignment="Center"
                                           Margin="10 0 0 0"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Advanced options card -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 24">
                            <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBlock Text="Advanced Options" Style="{StaticResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- VK Code row — Keyboard only -->
                        <Grid Margin="0 0 0 8">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMethod}" Value="Keyboard">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Virtual key code"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBlock Text="Windows VK code for the key to press (default: 126 = F22)."
                                                   Style="{StaticResource SettingDescriptionStyle}"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource InputStyle}"
                                             VerticalAlignment="Center"
                                             Text="{Binding VirtualKeyCode, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Mouse delta row — Mouse only -->
                        <Grid Margin="0 0 0 8">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedMethod}" Value="Mouse">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Style="{StaticResource SettingRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Mouse pixel delta"
                                                   Style="{StaticResource SettingLabelStyle}"/>
                                        <TextBlock Text="Pixels to move the cursor per pulse (default: 2 px)."
                                                   Style="{StaticResource SettingDescriptionStyle}"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource InputStyle}"
                                             VerticalAlignment="Center"
                                             Text="{Binding MousePixelDelta, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                    <TextBlock Grid.Column="2" Text="px"
                                               Style="{StaticResource FieldLabelStyle}"
                                               VerticalAlignment="Center"
                                               Margin="10 0 0 0"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Hint when no method-specific options apply -->
                        <TextBlock Margin="0 4 0 0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource FooterTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowAdvancedOptions}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            Select a simulation method above to see its advanced parameters.
                        </TextBlock>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
