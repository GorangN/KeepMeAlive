<UserControl x:Class="StatusUpdater.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StatusUpdater.Helpers">

    <!-- Semi-transparent backdrop -->
    <Grid>
        <Rectangle Fill="{DynamicResource OverlayBrush}"/>

        <!-- Settings panel -->
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Width="360"
                MaxHeight="580"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270"
                                  Color="#000000" Opacity="0.5"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ STICKY HEADER ═══ -->
                <Grid Grid.Row="0" Margin="20 18 20 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Settings"
                               Style="{StaticResource AppTitleStyle}"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding DataContext.ToggleSettingsCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Close">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                </Grid>

                <!-- ═══ SCROLLABLE CONTENT ═══ -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0 8 0 0">
                <StackPanel Margin="20 0 20 20">

                <!-- Separator -->
                <Rectangle Style="{StaticResource SeparatorStyle}" Margin="0 0 0 0"/>

                <!-- ═══ THEME ═══ -->
                <Grid Margin="0 10 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Theme"
                               Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ComboBoxStyle}"
                              SelectedItem="{Binding SettingsViewModel.SelectedTheme,
                                             RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}">
                        <ComboBox.Items>
                            <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Dark</system:String>
                            <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">Light</system:String>
                            <system:String xmlns:system="clr-namespace:System;assembly=mscorlib">System</system:String>
                        </ComboBox.Items>
                    </ComboBox>
                </Grid>

                <!-- ═══ STARTUP ═══ -->
                <Grid Margin="0 4 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="On startup"
                               Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleCheckBoxStyle}"
                              IsChecked="{Binding SettingsViewModel.StartOnBoot,
                                          RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                              Content="Start with Windows"
                              Foreground="{DynamicResource ForegroundBrush}"/>
                </Grid>

                <!-- ═══ NOTIFICATIONS ═══ -->
                <Grid Margin="0 4 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Notifications"
                               Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleCheckBoxStyle}"
                              IsChecked="{Binding SettingsViewModel.ShowNotifications,
                                          RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                              Content="Show tray notifications"
                              Foreground="{DynamicResource ForegroundBrush}"/>
                </Grid>

                <!-- Separator -->
                <Rectangle Style="{StaticResource SeparatorStyle}"/>

                <!-- ═══ SUBSCRIPTION ═══ -->
                <StackPanel Margin="0 10 0 0">
                    <TextBlock Text="Subscription"
                               Style="{StaticResource SectionLabelStyle}"
                               Margin="0 0 0 8"/>
                    <TextBlock Text="License Key"
                               Style="{StaticResource FooterTextStyle}"
                               Margin="0 0 0 4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource InputStyle}"
                                 Text="{Binding SettingsViewModel.LicenseKey,
                                        RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"/>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SettingsViewModel.ActivateLicenseCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                Content="Activate"
                                Width="70"
                                Margin="6 0 0 0"/>
                    </Grid>
                    <TextBlock Text="Subscription coming soon — enter your license key here when available."
                               Style="{StaticResource FooterTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0 6 0 0"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Style="{StaticResource SeparatorStyle}" Margin="0 14 0 4"/>

                <!-- ═══ SCHEDULED ACTION ═══ -->
                <StackPanel Margin="0 10 0 0">
                    <TextBlock Text="Scheduled Action"
                               Style="{StaticResource SectionLabelStyle}" Margin="0 0 0 8"/>

                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Enabled"
                                   Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1"
                                  Style="{StaticResource ToggleCheckBoxStyle}"
                                  IsChecked="{Binding SettingsViewModel.ScheduledActionEnabled,
                                              RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                  Content="Run action at scheduled time"
                                  Foreground="{DynamicResource ForegroundBrush}"/>
                    </Grid>

                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Action"
                                   Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource ComboBoxStyle}"
                                  ItemsSource="{Binding SettingsViewModel.AvailableScheduledActions,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding SettingsViewModel.SelectedScheduledAction,
                                                 RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                  IsEnabled="{Binding SettingsViewModel.ScheduledActionEnabled,
                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>

                    <Grid Margin="0 0 0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date / Time"
                                   Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource InputStyle}"
                                 IsEnabled="{Binding SettingsViewModel.ScheduledActionEnabled,
                                              RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBox.Text>
                                <Binding Path="SettingsViewModel.ScheduledActionTime"
                                         RelativeSource="{RelativeSource AncestorType=Window}"
                                         UpdateSourceTrigger="PropertyChanged"
                                         Mode="TwoWay">
                                    <Binding.ValidationRules>
                                        <helpers:DateTimeFormatValidationRule ValidatesOnTargetUpdated="False"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                    </Grid>
                    <TextBlock Text="Format: dd:MM:yyyy:HH:mm:ss  (e.g. 01:04:2026:22:30:00)"
                               Style="{StaticResource FooterTextStyle}"
                               TextWrapping="Wrap" Margin="110 0 0 0"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Style="{StaticResource SeparatorStyle}" Margin="0 14 0 4"/>

                <!-- ═══ SAVE BUTTON ═══ -->
                <Button Style="{StaticResource IndustrialButtonStyle}"
                        Command="{Binding SettingsViewModel.SaveAndCloseCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                        Content="Save"/>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
