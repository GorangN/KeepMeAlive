<UserControl x:Class="KeepMeAlive.Views.LicensePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <DockPanel>

            <!-- Footer actions bar -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BackgroundBrush}"
                    Padding="40 16">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <Border.BorderThickness>0 0.5 0 0</Border.BorderThickness>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Privacy Policy"
                               Style="{StaticResource FooterTextStyle}"
                               Margin="0 0 20 0"
                               Cursor="Hand"/>
                    <TextBlock Text="Terms of Service"
                               Style="{StaticResource FooterTextStyle}"
                               Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="40 36 40 24">

                    <!-- Page header -->
                    <TextBlock Text="License" Style="{StaticResource PageHeadlineStyle}"/>
                    <TextBlock Text="Manage your application tier and license key."
                               Style="{StaticResource PageSubtitleStyle}"
                               Margin="0 6 0 32"/>

                    <!-- Account &amp; License card -->
                    <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20"
                            MaxWidth="560" HorizontalAlignment="Left">
                        <StackPanel>

                            <!-- Card header -->
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 22">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <TextBlock Text="Account &amp; License"
                                           Style="{StaticResource CardHeaderStyle}"/>
                            </StackPanel>

                            <!-- License key label -->
                            <TextBlock Text="LICENSE KEY"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Margin="0 0 0 10"/>

                            <!-- Input + Activate button row -->
                            <Grid Margin="0 0 0 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{DynamicResource SurfaceContainerLowestBrush}"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xE8D7;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                   Opacity="0.4"
                                                   VerticalAlignment="Center"
                                                   Margin="14 0 0 0"/>
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource InputStyle}"
                                                 Text="{Binding LicenseKey, Mode=TwoWay}"
                                                 FontFamily="Courier New"
                                                 FontSize="12"
                                                 Background="Transparent"/>
                                    </Grid>
                                </Border>
                                <Button Grid.Column="2"
                                        Style="{StaticResource ActivateButtonStyle}"
                                        Command="{Binding ActivateLicenseCommand}"
                                        Content="Activate"/>
                            </Grid>

                            <!-- Info hint -->
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center" Margin="0 0 6 0"/>
                                <TextBlock Text="Activation may take up to 30 seconds to propagate."
                                           Style="{StaticResource FooterTextStyle}"/>
                            </StackPanel>

                            <!-- Status / expiry chips -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{DynamicResource SurfaceContainerLowestBrush}"
                                        CornerRadius="10"
                                        Padding="14 12">
                                    <StackPanel>
                                        <TextBlock Text="STATUS"
                                                   Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0 0 0 6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{DynamicResource PrimaryBrush}"
                                                     VerticalAlignment="Center"
                                                     Margin="0 0 6 0"/>
                                            <TextBlock Text="Free Tier"
                                                       FontFamily="{StaticResource InterFont}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Background="{DynamicResource SurfaceContainerLowestBrush}"
                                        CornerRadius="10"
                                        Padding="14 12">
                                    <StackPanel>
                                        <TextBlock Text="EXPIRES"
                                                   Style="{StaticResource FieldLabelStyle}"
                                                   Margin="0 0 0 6"/>
                                        <TextBlock Text="—"
                                                   FontFamily="{StaticResource InterFont}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurfaceBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
