<UserControl x:Class="KeepMeAlive.Views.LicensePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <DockPanel>

            <!-- Footer actions bar -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource BackgroundBrush}"
                    Padding="40 16">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource OutlineVariantColor}" Opacity="0.15"/>
                </Border.BorderBrush>
                <Border.BorderThickness>0 0.5 0 0</Border.BorderThickness>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: footer links -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Privacy Policy"
                                   Style="{StaticResource FooterTextStyle}"
                                   Margin="0 0 20 0"
                                   Cursor="Hand"/>
                        <TextBlock Text="Terms of Service"
                                   Style="{StaticResource FooterTextStyle}"
                                   Margin="0 0 20 0"
                                   Cursor="Hand"/>
                    </StackPanel>

                    <!-- Reset button -->
                    <Button Grid.Column="1"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="Reset to Default"/>

                    <!-- Save button -->
                    <Button Grid.Column="3"
                            Style="{StaticResource SaveButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Content="Save Changes"/>
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="40 36 40 24">

                    <!-- Page header -->
                    <TextBlock Text="License &amp; Settings" Style="{StaticResource PageHeadlineStyle}"/>
                    <TextBlock Text="Manage your application tier and fine-tune your workflow experience."
                               Style="{StaticResource PageSubtitleStyle}"
                               Margin="0 6 0 32"/>

                    <!-- Two-column grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="280"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*" MinWidth="220"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ═══ Left column ═══ -->
                        <StackPanel Grid.Column="0">

                            <!-- Account &amp; License card -->
                            <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                                <StackPanel>

                                    <!-- Card header -->
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 22">
                                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   VerticalAlignment="Center" Margin="0 0 10 0"/>
                                        <TextBlock Text="Account &amp; License"
                                                   Style="{StaticResource CardHeaderStyle}"/>
                                    </StackPanel>

                                    <!-- License key label -->
                                    <TextBlock Text="LICENSE KEY"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0 0 0 10"/>

                                    <!-- Input + Activate button row -->
                                    <Grid Margin="0 0 0 10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource SurfaceContainerLowestBrush}"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="&#xE8D7;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                           Opacity="0.4"
                                                           VerticalAlignment="Center"
                                                           Margin="14 0 0 0"/>
                                                <TextBox Grid.Column="1"
                                                         Style="{StaticResource InputStyle}"
                                                         Text="{Binding LicenseKey, Mode=TwoWay}"
                                                         FontFamily="Courier New"
                                                         FontSize="12"
                                                         Background="Transparent"/>
                                            </Grid>
                                        </Border>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource ActivateButtonStyle}"
                                                Command="{Binding ActivateLicenseCommand}"
                                                Content="Activate"/>
                                    </Grid>

                                    <!-- Info hint -->
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                                        <TextBlock Text="&#xE946;"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                   VerticalAlignment="Center" Margin="0 0 6 0"/>
                                        <TextBlock Text="Activation may take up to 30 seconds to propagate."
                                                   Style="{StaticResource FooterTextStyle}"/>
                                    </StackPanel>

                                    <!-- Status / expiry chips -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource SurfaceContainerLowestBrush}"
                                                CornerRadius="10"
                                                Padding="14 12">
                                            <StackPanel>
                                                <TextBlock Text="STATUS"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0 0 0 6"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{DynamicResource PrimaryBrush}"
                                                             VerticalAlignment="Center"
                                                             Margin="0 0 6 0"/>
                                                    <TextBlock Text="Free Tier"
                                                               FontFamily="{StaticResource InterFont}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2"
                                                Background="{DynamicResource SurfaceContainerLowestBrush}"
                                                CornerRadius="10"
                                                Padding="14 12">
                                            <StackPanel>
                                                <TextBlock Text="EXPIRES"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0 0 0 6"/>
                                                <TextBlock Text="—"
                                                           FontFamily="{StaticResource InterFont}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- ═══ Right column ═══ -->
                        <StackPanel Grid.Column="2">

                            <!-- Preferences card -->
                            <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                                <StackPanel>

                                    <!-- Card header -->
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 22">
                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   VerticalAlignment="Center" Margin="0 0 10 0"/>
                                        <TextBlock Text="Preferences" Style="{StaticResource CardHeaderStyle}"/>
                                    </StackPanel>

                                    <!-- Start-up behaviour label -->
                                    <TextBlock Text="START-UP BEHAVIOUR"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0 0 0 12"/>

                                    <!-- Start on boot row -->
                                    <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="Launch at system startup"
                                                       Style="{StaticResource SettingLabelStyle}"/>
                                            <CheckBox Grid.Column="1"
                                                      Style="{StaticResource ToggleCheckBoxStyle}"
                                                      IsChecked="{Binding StartOnBoot, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Notifications label -->
                                    <TextBlock Text="NOTIFICATIONS"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0 16 0 12"/>

                                    <!-- Activity alerts row -->
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="&#xEA8F;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0 0 10 0"/>
                                                <TextBlock Text="Activity alerts"
                                                           Style="{StaticResource SettingLabelStyle}"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Style="{StaticResource ToggleCheckBoxStyle}"
                                                      IsChecked="{Binding ShowNotifications, Mode=TwoWay}"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
