<Window x:Class="KeepMeAlive.Views.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KeepMeAlive.ViewModels"
        xmlns:models="clr-namespace:KeepMeAlive.Models"
        xmlns:views="clr-namespace:KeepMeAlive.Views"
        Title="KeepMeAlive"
        MinWidth="860" MinHeight="580"
        Width="1020" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Border CornerRadius="14"
            Background="{DynamicResource BackgroundBrush}"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Direction="270"
                              Color="#000000" Opacity="0.14"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Title bar -->
                <RowDefinition Height="44"/>
                <!-- Sidebar + content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="240"/>
                <!-- Content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--                   TITLE BAR                         -->
            <!-- ═══════════════════════════════════════════════════ -->

            <views:TitleBarView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"/>

            <!-- Horizontal divider under title bar -->
            <Rectangle Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Height="0.5"
                       VerticalAlignment="Bottom"
                       Fill="{DynamicResource OutlineVariantBrush}"
                       Opacity="0.2"/>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--                    SIDEBAR                          -->
            <!-- ═══════════════════════════════════════════════════ -->

            <Border Grid.Row="1" Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}">

                <DockPanel Margin="0">

                    <!-- Sidebar bottom: version + update badge -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="16 0 16 20">

                        <Rectangle Height="0.5"
                                   Fill="{DynamicResource OutlineVariantBrush}"
                                   Opacity="0.3"
                                   Margin="4 0 4 14"/>

                        <!-- Update badge -->
                        <Button Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding UpdateViewModel.OpenReleasePageCommand}"
                                Visibility="{Binding UpdateViewModel.UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                Content="Update available"
                                Margin="0 0 0 8"
                                HorizontalAlignment="Stretch"/>

                        <TextBlock Text="{Binding UpdateViewModel.AppVersion, StringFormat='v{0}'}"
                                   Style="{StaticResource FooterTextStyle}"
                                   Margin="4 0 0 0"/>
                    </StackPanel>

                    <!-- Nav items -->
                    <StackPanel DockPanel.Dock="Top" Margin="12 12" VerticalAlignment="Top">

                        <!-- Dashboard -->
                        <Button Margin="0 2"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static models:NavigationPage.Dashboard}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavItemStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Dashboard">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="{DynamicResource NavItemActiveBgBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Margin="4 0">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Scheduling -->
                        <Button Margin="0 2"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static models:NavigationPage.Scheduling}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavItemStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Scheduling">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="{DynamicResource NavItemActiveBgBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Margin="4 0">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <TextBlock Text="Scheduling" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Advanced -->
                        <Button Margin="0 2"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static models:NavigationPage.Advanced}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavItemStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Advanced">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="{DynamicResource NavItemActiveBgBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Margin="4 0">
                                <TextBlock Text="&#xE9E9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <TextBlock Text="Advanced" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- License -->
                        <Button Margin="0 2"
                                HorizontalAlignment="Stretch"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static models:NavigationPage.License}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavItemStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="License">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="{DynamicResource NavItemActiveBgBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Margin="4 0">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0 0 10 0"/>
                                <TextBlock Text="License" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Sidebar / content separator -->
            <Rectangle Grid.Row="1" Grid.Column="0"
                       Width="0.5"
                       HorizontalAlignment="Right"
                       Fill="{DynamicResource OutlineVariantBrush}"
                       Opacity="0.2"/>

            <!-- ═══════════════════════════════════════════════════ -->
            <!--                  CONTENT AREA                       -->
            <!-- ═══════════════════════════════════════════════════ -->

            <Grid Grid.Row="1" Grid.Column="1">

                <!-- Dashboard page -->
                <views:DashboardView
                    Visibility="{Binding DataContext.CurrentPage,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource NavPageVisConverter},
                                         ConverterParameter=Dashboard}"/>

                <!-- Scheduling page -->
                <views:SchedulingPageView
                    DataContext="{Binding SettingsViewModel}"
                    Visibility="{Binding DataContext.CurrentPage,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource NavPageVisConverter},
                                         ConverterParameter=Scheduling}"/>

                <!-- Advanced page -->
                <views:AdvancedPageView
                    DataContext="{Binding DashboardViewModel}"
                    Visibility="{Binding DataContext.CurrentPage,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource NavPageVisConverter},
                                         ConverterParameter=Advanced}"/>

                <!-- License page -->
                <views:LicensePageView
                    DataContext="{Binding SettingsViewModel}"
                    Visibility="{Binding DataContext.CurrentPage,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource NavPageVisConverter},
                                         ConverterParameter=License}"/>

            </Grid>

        </Grid>
    </Border>
</Window>
