<Window x:Class="StatusUpdater.Views.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StatusUpdater.ViewModels"
        xmlns:views="clr-namespace:StatusUpdater.Views"
        Title="Status Updater"
        Width="400" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Background="Transparent">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer transparent area absorbs clicks to hide window -->
    <Grid>
        <Border CornerRadius="12"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270"
                                  Color="#000000" Opacity="0.3"/>
            </Border.Effect>

            <DockPanel>
                <!-- ═══ HEADER ═══ -->
                <Grid DockPanel.Dock="Top"
                      Background="{DynamicResource Surface2Brush}"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Column="0"
                               Text="Status Updater"
                               Style="{StaticResource AppTitleStyle}"
                               Margin="12 10 0 10"/>

                    <!-- Icon buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0 0 8 0"
                                VerticalAlignment="Center">

                        <!-- Update badge -->
                        <Button Style="{StaticResource IconButtonStyle}"
                                Command="{Binding UpdateViewModel.OpenReleasePageCommand}"
                                Visibility="{Binding UpdateViewModel.UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="Update available">
                            <Grid>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                <Ellipse Width="7" Height="7"
                                         Fill="{DynamicResource AccentBrush}"
                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                         Margin="0 0 -1 0"/>
                            </Grid>
                        </Button>

                        <!-- Settings -->
                        <Button Style="{StaticResource IconButtonStyle}"
                                Command="{Binding ToggleSettingsCommand}"
                                ToolTip="Settings">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ═══ FOOTER ═══ -->
                <Grid DockPanel.Dock="Bottom"
                      Background="{DynamicResource Surface2Brush}"
                      Height="28">
                    <TextBlock Text="{Binding UpdateViewModel.AppVersion, StringFormat='v{0}'}"
                               Style="{StaticResource FooterTextStyle}"
                               Margin="12 0 0 0"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- ═══ MAIN CONTENT ═══ -->
                <Grid>
                    <!-- Dashboard view (DataTemplate resolves DashboardViewModel → DashboardView) -->
                    <ContentPresenter Content="{Binding DashboardViewModel}"/>

                    <!-- Settings overlay (modal) -->
                    <views:SettingsView
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                        Panel.ZIndex="10"/>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
