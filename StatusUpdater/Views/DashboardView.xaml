<UserControl x:Class="StatusUpdater.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:StatusUpdater.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="VisConv"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20 16 20 16">

                <!-- ═══ STATUS ROW ═══ -->
                <Grid Margin="0 0 0 14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="StatusDot"
                             Grid.Column="0"
                             Width="12" Height="12"
                             VerticalAlignment="Center"
                             Margin="0 0 10 0"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColorConverter}}">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" CenterX="6" CenterY="6"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="PulseBegin">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        From="1.0" To="1.5" Duration="0:0:0.7"/>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        From="1.0" To="1.5" Duration="0:0:0.7"/>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="1.0" To="0.5" Duration="0:0:0.7"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseBegin"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Grid.Column="1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatusTextStyle}">
                                <Setter Property="Text" Value="Stopped"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubtleBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Running"/>
                                        <Setter Property="Foreground" Value="{DynamicResource RunningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Separator -->
                <Rectangle Style="{StaticResource SeparatorStyle}" Margin="0 0 0 14"/>

                <!-- ═══ METHOD ═══ -->
                <Grid Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Method"
                               Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ComboBoxStyle}"
                              SelectedItem="{Binding SelectedMethod, Mode=TwoWay}"
                              IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}">
                        <ComboBox.Items>
                            <vm:KeepAliveMethod>Keyboard</vm:KeepAliveMethod>
                            <vm:KeepAliveMethod>Mouse</vm:KeepAliveMethod>
                        </ComboBox.Items>
                    </ComboBox>
                </Grid>

                <!-- ═══ INTERVAL ═══ -->
                <Grid Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Interval"
                               Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource InputStyle}"
                             Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Grid.Column="2" Text="s"
                               Style="{StaticResource SectionLabelStyle}" Margin="8 0 0 0"/>
                </Grid>

                <!-- ═══ KEEP AWAKE ═══ -->
                <Grid Margin="0 0 0 14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Keep awake"
                               Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleCheckBoxStyle}"
                              IsChecked="{Binding KeepAwakeEnabled}"
                              IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                              Content="Prevent sleep &amp; display off"
                              Foreground="{DynamicResource ForegroundBrush}"/>
                </Grid>

                <!-- ═══ ADVANCED OPTIONS (collapsible) ═══ -->
                <Border Background="{DynamicResource InputBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Margin="0 0 0 16">
                    <StackPanel>
                        <!-- Toggle header -->
                        <Button Command="{Binding ToggleAdvancedOptionsCommand}"
                                HorizontalAlignment="Stretch"
                                Width="NaN" Height="28"
                                Padding="10 0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Advanced options"
                                                       Style="{StaticResource SectionLabelStyle}"
                                                       HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                       Foreground="{DynamicResource SubtleBrush}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE972;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowAdvancedOptions}" Value="True">
                                                                <Setter Property="Text" Value="&#xE971;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Advanced content -->
                        <StackPanel Visibility="{Binding ShowAdvancedOptions, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="10 4 10 10">

                            <!-- VK Code row (keyboard method) -->
                            <Grid Margin="0 4 0 0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedMethod}" Value="Keyboard">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VK code"
                                           Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource InputStyle}"
                                         Text="{Binding VirtualKeyCode, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>

                            <!-- Mouse delta row (mouse method) -->
                            <Grid Margin="0 4 0 0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedMethod}" Value="Mouse">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mouse delta"
                                           Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource InputStyle}"
                                         Text="{Binding MousePixelDelta, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                <TextBlock Grid.Column="2" Text="px"
                                           Style="{StaticResource SectionLabelStyle}" Margin="8 0 0 0"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ START / STOP ═══ -->
                <Button Command="{Binding StartCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        Style="{StaticResource IndustrialButtonStyle}"
                        Content="Start"
                        Margin="0 0 0 10"/>

                <Button Command="{Binding StopCommand}"
                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                        Style="{StaticResource DangerButtonStyle}"
                        Content="Stop"
                        Margin="0 0 0 10"/>

                <!-- ═══ IDLE COUNTER ═══ -->
                <TextBlock Text="{Binding IdleTimeDisplay}"
                           Style="{StaticResource IdleTextStyle}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
