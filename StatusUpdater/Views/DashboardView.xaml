<UserControl x:Class="KeepMeAlive.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40 36 40 36">

                <!-- ═══ Page header ═══ -->
                <TextBlock Text="Dashboard" Style="{StaticResource PageHeadlineStyle}"/>
                <TextBlock Text="Monitor and control your keep-alive session."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0 6 0 32"/>

                <!-- ═══ Status hero card ═══ -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status text + dot -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                <!-- Animated status dot -->
                                <Ellipse x:Name="StatusDot"
                                         Width="10" Height="10"
                                         VerticalAlignment="Center"
                                         Margin="0 0 10 0"
                                         Fill="{Binding IsRunning, Converter={StaticResource BoolToColorConverter}}">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="5" CenterY="5"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="PulseBegin">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                    From="1.0" To="1.6" Duration="0:0:0.7"/>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                    From="1.0" To="1.6" Duration="0:0:0.7"/>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="1.0" To="0.4" Duration="0:0:0.7"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="PulseBegin"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                                            <Setter Property="Text" Value="STOPPED"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Text" Value="RUNNING"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource RunningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- Large hero status -->
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource HeroStatusStyle}">
                                        <Setter Property="Text" Value="Idle"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SurfaceContainerHighestBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="Active"/>
                                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="{Binding IdleTimeDisplay}"
                                       Style="{StaticResource IdleTextStyle}"
                                       Margin="0 10 0 0"/>
                        </StackPanel>

                        <!-- Start / Stop button -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Command="{Binding StartCommand}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Start"
                                    Width="120"/>

                            <Button Command="{Binding StopCommand}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Content="Stop"
                                    Width="120"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
