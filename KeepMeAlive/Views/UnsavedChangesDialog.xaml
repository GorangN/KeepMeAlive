<Window x:Class="KeepMeAlive.Views.UnsavedChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Background="#66000000"
        ResizeMode="NoResize">

    <!-- Semi-transparent overlay fills the entire window; card is centered -->
    <Grid>
        <Border Width="380"
                CornerRadius="14"
                Background="{DynamicResource BackgroundBrush}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="28 24 28 24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.28" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0 0 10 0"/>
                    <TextBlock Text="Unsaved Changes"
                               Style="{StaticResource CardHeaderStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Body -->
                <TextBlock Grid.Row="1"
                           Text="You have unsaved changes. What would you like to do?"
                           Style="{StaticResource SettingDescriptionStyle}"
                           TextWrapping="Wrap"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Don't Save"
                            Style="{StaticResource GhostButtonStyle}"
                            Width="110"
                            Margin="0 0 10 0"
                            Click="DiscardButton_Click"/>
                    <Button Content="Save"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="90"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
