<UserControl x:Class="KeepMeAlive.Views.TitleBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="44">

    <Border Background="{DynamicResource SurfaceBrush}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid Margin="20 0 8 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: App branding -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="KeepMeAlive"
                           Style="{StaticResource AppTitleStyle}"
                           FontSize="15"
                           VerticalAlignment="Center"/>
                <TextBlock Text="UTILITY SUITE"
                           FontFamily="{StaticResource InterFont}"
                           FontSize="9"
                           FontWeight="Medium"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Opacity="0.6"
                           VerticalAlignment="Bottom"
                           Margin="8 0 0 3"/>
            </StackPanel>

            <!-- Right: Minimize + Hide-to-tray -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource IconButtonStyle}"
                        Click="MinimizeButton_Click"
                        ToolTip="Minimize">
                    <TextBlock Text="&#xE921;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="9"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                </Button>
                <Button Style="{StaticResource IconButtonStyle}"
                        Command="{Binding HideWindowCommand}"
                        ToolTip="Minimize to tray">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
