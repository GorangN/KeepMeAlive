<UserControl x:Class="KeepMeAlive.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40 36 40 36">

                <!-- ═══ Page header ═══ -->
                <TextBlock Text="Dashboard" Style="{StaticResource PageHeadlineStyle}"/>
                <TextBlock Text="Start quickly, stay available, and keep the app out of the way."
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0 6 0 32"/>

                <!-- ═══ Status hero card ═══ -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status text + dot -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                <!-- Animated status dot -->
                                <Ellipse x:Name="StatusDot"
                                         Width="10" Height="10"
                                         VerticalAlignment="Center"
                                         Margin="0 0 10 0"
                                         Fill="{Binding DashboardViewModel.IsRunning, Converter={StaticResource BoolToColorConverter}}">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="5" CenterY="5"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DashboardViewModel.IsRunning}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="PulseBegin">
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                    From="1.0" To="1.6" Duration="0:0:0.7"/>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                    From="1.0" To="1.6" Duration="0:0:0.7"/>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="1.0" To="0.4" Duration="0:0:0.7"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="PulseBegin"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                                            <Setter Property="Text" Value="STOPPED"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DashboardViewModel.IsRunning}" Value="True">
                                                    <Setter Property="Text" Value="RUNNING"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource RunningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- Large hero status -->
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource HeroStatusStyle}">
                                        <Setter Property="Text" Value="Idle"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SurfaceContainerHighestBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DashboardViewModel.IsRunning}" Value="True">
                                                <Setter Property="Text" Value="Active"/>
                                                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="{Binding DashboardViewModel.IdleTimeDisplay}"
                                       Style="{StaticResource IdleTextStyle}"
                                       Margin="0 10 0 0"/>

                            <WrapPanel Margin="0 14 0 0" ItemHeight="30">
                                <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                        CornerRadius="999"
                                        Padding="12 6"
                                        Margin="0 0 8 8">
                                    <TextBlock Text="{Binding DashboardViewModel.SelectedMethod, StringFormat='{}{0} mode'}"
                                               Style="{StaticResource FooterTextStyle}"/>
                                </Border>
                                <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                        CornerRadius="999"
                                        Padding="12 6"
                                        Margin="0 0 8 8">
                                    <TextBlock Text="{Binding DashboardViewModel.IntervalSeconds, StringFormat='{}{0}s cadence'}"
                                               Style="{StaticResource FooterTextStyle}"/>
                                </Border>
                                <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                        CornerRadius="999"
                                        Padding="12 6"
                                        Margin="0 0 8 8">
                                    <TextBlock Text="No admin rights"
                                               Style="{StaticResource FooterTextStyle}"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Start / Stop button -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Command="{Binding DashboardViewModel.StartCommand}"
                                    Visibility="{Binding DashboardViewModel.IsRunning, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Start Keep-Alive"
                                    Width="160"/>

                            <Button Command="{Binding DashboardViewModel.StopCommand}"
                                    Visibility="{Binding DashboardViewModel.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Content="Stop Session"
                                    Width="160"/>

                            <TextBlock Text="Runs silently in the tray and keeps your presence active."
                                       Style="{StaticResource FooterTextStyle}"
                                       TextWrapping="Wrap"
                                       Width="160"
                                       Margin="0 12 0 0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Keep Awake card ═══ -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBlock Text="Keep Awake" Style="{StaticResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- Prevent sleep & display off -->
                        <Border Style="{StaticResource SettingRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Prevent sleep &amp; display off"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Uses Windows power management to keep the screen and system awake."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleCheckBoxStyle}"
                                          IsChecked="{Binding DashboardViewModel.KeepAwakeEnabled}"
                                          IsEnabled="{Binding DashboardViewModel.IsRunning, Converter={StaticResource InverseBoolConverter}}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ═══ Preferences card ═══ -->
                <Border Style="{StaticResource CardSectionStyle}" Margin="0 0 0 20">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0 0 10 0"/>
                            <TextBlock Text="Preferences" Style="{StaticResource CardHeaderStyle}"/>
                        </StackPanel>

                        <!-- Launch at startup -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Launch at system startup"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Start KeepMeAlive automatically when Windows boots."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleCheckBoxStyle}"
                                          IsChecked="{Binding SettingsViewModel.StartOnBoot, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Start minimized to tray -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Start minimized to tray"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Hide the window on launch and run silently in the system tray."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleCheckBoxStyle}"
                                          IsChecked="{Binding SettingsViewModel.StartMinimizedToTray, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Activity alerts -->
                        <Border Style="{StaticResource SettingRowStyle}" Margin="0 0 0 16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Activity alerts"
                                               Style="{StaticResource SettingLabelStyle}"/>
                                    <TextBlock Text="Show tray notifications when keep-alive starts or stops."
                                               Style="{StaticResource SettingDescriptionStyle}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1"
                                          Style="{StaticResource ToggleCheckBoxStyle}"
                                          IsChecked="{Binding SettingsViewModel.ShowNotifications, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Save button -->
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource SaveButtonStyle}"
                                Command="{Binding SettingsViewModel.SaveCommand}"
                                Content="Save Changes"/>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
